# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
ENABLE_CLUSTER=false
WORKERS=4
WORKER_50=false
BASE_URL=http://localhost:3001

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=false

# ============================================
# SECURITY CONFIGURATION
# ============================================
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-this-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CSP=true
ENABLE_CORS=true
ENABLE_CSRF=false
ENABLE_SECURITY_MW=true
ENABLE_RATE_LIMIT=true
ENABLE_CRON=true
ENABLE_SLOW_QUERY_LOG=true
ENABLE_SYSTEM_HEALTH_LOG=true
ENABLE_API_TRACKING=true
ENABLE_IMAGE_COMPRESSION=true
ENABLE_SWAGGER=true
ENABLE_COMPRESSION=true

# ============================================
# RATE LIMITING
# ============================================
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# CRON JOBS
# ============================================
CRON_TIMEZONE=Asia/Kolkata

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# REDIS CONFIGURATION (Optional - for Bull queues)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# DATETIME CONFIGURATION
# ============================================
DEFAULT_TIMEZONE=UTC
DEFAULT_DATE_FORMAT=YYYY-MM-DD 24H

# ============================================
# IMAGE PROCESSING
# ============================================
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080

# ============================================
# PDF GENERATION
# ============================================
PDF_TIMEOUT=30000
